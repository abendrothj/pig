[[workers]]
id = "my-worker"
url = "http://192.168.1.100:9847"
# auth_token_env = "MY_WORKER_TOKEN"   # optional; worker must have auth enabled

[models.entries."qwen3-8b-q4"]
format = "gguf"
path = "/path/to/Qwen3-8B-Q4_K_M.gguf"
backend = "llama_cpp"
context_tokens = 8192
roles = ["reasoning"]
reasoning = true    # supports /think mode; requests with requirements.reasoning=true route here
tool_calling = true # explicit override; llama_cpp defaults to true, mlx defaults to false

# Optional: backend execution parameters. All fields are optional.
# gpu_layers: number of transformer layers to offload to GPU (-1 = all)
# flash_attention: significant throughput gain on CUDA and Metal
# parallel: concurrent request slots (continuous batching)
# cache_type_k / cache_type_v: KV cache quantization ("q8_0" halves VRAM, minimal quality loss)
[models.entries."qwen3-8b-q4".execution_config]
gpu_layers = -1
flash_attention = true
parallel = 2
cache_type_k = "q8_0"
cache_type_v = "q8_0"

[models.roles.reasoning]
candidates = ["qwen3-8b-q4"]

# --- MLX backend (Apple Silicon, HuggingFace model directories) ---
# Use instead of llama_cpp when running mlx_lm models on macOS/Apple Silicon.
# Install: pip install mlx-lm
#
# [worker.runtime.llama_cpp]
# enabled = false
#
# [worker.runtime.mlx]
# enabled = true
# server_executable = "mlx_lm.server"   # must be on PATH
#
# [models.entries."qwen3-8b-mlx"]
# format = "mlx"
# path = "/path/to/mlx-community/Qwen3-8B-4bit"   # HuggingFace model directory
# backend = "mlx"
# context_tokens = 32768
# roles = ["reasoning"]
#
# [models.entries."qwen3-8b-mlx".execution_config]
# trust_remote_code = false   # set true only for models that require it

# --- Named profiles for remote coordinators (pig --profile <name> ...) ---
# [profiles.remote]
# mode = "remote"
# coordinator_url = "http://spectre:3001"
# token_env = "REMOTE_COORDINATOR_TOKEN"
