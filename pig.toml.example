[trust]
# Keep dangerous capabilities disabled unless a workflow is trusted.
allow_filesystem_read = false
allow_filesystem_write = false
allow_filesystem_enumerate = false
allow_shell = false
allow_network = false
allow_subprocess = false
allow_code_graph_read = false
# v0.5 local model inference (see docs/local-inference.md)
allow_model_inference = false
allow_model_load = false
allow_network_loopback = false
allow_network_private = false
allow_accelerator_use = false

# Explicit filesystem roots only — no implicit cwd/repo root.
# Required when any filesystem_* capability is enabled.
filesystem_roots = []

# Allowed network endpoints (host, host:port, or URL prefix).
# Required when allow_network is true unless you use allow_plugins.
network_endpoints = []

# Optional escape hatch for specific trusted plugins.
allow_plugins = []

# `code-graph query` (read-only structural code intelligence via codebase-memory-mcp)
# requires allow_code_graph_read = true above. The provider binary is resolved from
# LAO_CODEBASE_MEMORY_MCP_PATH if set, else from PATH.
