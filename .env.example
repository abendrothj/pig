# Directory scanned for plugin shared libraries.
# Defaults to plugins/
# LAO_PLUGINS_DIR=plugins

# Directory used for workflow step output cache.
# Defaults to cache/
# LAO_CACHE_DIR=cache

# Explicitly allow shell-capable workflows during local trusted runs.
# Prefer pig.toml trust policy for production once configured.
# LAO_ALLOW_SHELL=0

# Path to a whisper.cpp executable used by WhisperPlugin.
# WHISPER_CPP_PATH=/path/to/whisper.cpp
